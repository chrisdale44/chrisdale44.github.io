<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --cream: #F5F1EB;
    --dark: #0E0E0E;
    --mid: #2A2A2A;
    --muted: #7A7A7A;
    --border: #E0DBD3;
    --font-serif: 'DM Serif Display', serif;
    --font-sans: 'Inter', sans-serif;
  }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-sans);
    background: var(--cream);
    color: var(--dark);
    line-height: 1.6;
    overflow-x: hidden;
  }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }

  /* Nav */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 2.5rem;
    mix-blend-mode: difference;
    color: #fff;
  }
  .nav-logo { font-family: var(--font-serif); font-size: 1.1rem; }
  .nav-back {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    opacity: 0.7; transition: opacity 0.2s;
  }
  .nav-back:hover { opacity: 1; }

  /* Hero */
  .cs-hero {
    background: var(--dark); color: #fff;
    padding: 10rem 2.5rem 5rem; min-height: 55vh;
    display: flex; flex-direction: column; justify-content: flex-end;
  }
  .cs-hero-inner { max-width: 1100px; margin: 0 auto; width: 100%; }
  .section-tag {
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; opacity: 0.4; margin-bottom: 1rem;
  }
  .cs-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 1.0; letter-spacing: -0.02em; margin-bottom: 1rem;
  }
  .cs-subtitle {
    font-size: 1rem; opacity: 0.5; max-width: 500px; line-height: 1.6;
  }

  /* Content sections */
  .cs-section { padding: 4rem 2.5rem; }
  .cs-section:nth-child(even) { background: #fff; }
  .cs-inner { max-width: 1100px; margin: 0 auto; }

  /* Before/After */
  .before-after {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 3rem;
  }
  .before-after-item img {
    width: 100%; border-radius: 4px; border: 1px solid var(--border);
  }
  .img-label {
    font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em;
    text-transform: uppercase; opacity: 0.4; margin-top: 0.6rem; text-align: center;
  }

  /* Single image */
  .cs-image { border-radius: 4px; border: 1px solid var(--border); width: auto; margin-bottom: 3rem; max-width: 1000px; object-fit: cover; margin: 1rem auto; }

  /* Content grid */
  .cs-content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .cs-content-grid.single { grid-template-columns: 1fr; max-width: 720px; }

  /* Tech tags */
  .tech-heading {
    font-family: var(--font-serif); font-size: 1.4rem;
    margin-bottom: 1.2rem; letter-spacing: -0.01em;
  }
  .tech-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .tech-tag {
    font-size: 0.72rem; font-weight: 500; letter-spacing: 0.04em;
    border: 1px solid var(--border); border-radius: 100px;
    padding: 0.38rem 0.85rem; color: var(--mid);
    transition: border-color 0.2s, color 0.2s;
  }
  .tech-tag:hover { border-color: var(--dark); color: var(--dark); }

  /* Bullets */
  .cs-bullets { list-style: none; padding: 0; }
  .cs-bullets li {
    font-size: 0.9rem; 
    line-height: 1.65; color: var(--mid);
    padding: 0.75rem 0; 
    padding-left: 1.2rem; position: relative;
  }
  .cs-bullets li::before {
    content: ''; position: absolute; left: 0; top: 1.1rem;
    width: 5px; height: 5px; border-radius: 50%; background: var(--muted);
  }
  .cs-bullets li:last-child { border-bottom: none; }

  /* Description text */
  .cs-desc { font-size: 0.95rem; line-height: 1.7; color: var(--mid); }
  .cs-desc + .cs-desc { margin-top: 1rem; }

  /* CTA */
  .cs-cta {
    margin-top: 2rem;
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.9rem 1.8rem; background: var(--dark); color: #fff;
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    border-radius: 2px; transition: opacity 0.2s;
  }
  .cs-cta:hover { opacity: 0.8; }

  /* Divider */
  .cs-divider { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

  /* Fade-in */
  .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .fade-in.visible { opacity: 1; transform: none; }
  .delay-1 { transition-delay: 0.12s; }
  .delay-2 { transition-delay: 0.24s; }

  /* Responsive */
  @media (max-width: 768px) {
    .nav { padding: 1rem 1.2rem; }
    .cs-hero { padding: 8rem 1.2rem 3rem; }
    .cs-section { padding: 2.5rem 1.2rem; }
    .before-after { grid-template-columns: 1fr; }
    .cs-content-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const fadeEls = document.querySelectorAll('.fade-in');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    fadeEls.forEach(el => observer.observe(el));
  });
</script>
