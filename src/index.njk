---
title: Christopher Dale · Full Stack Engineer & Photographer
layout: layouts/base.njk
---

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #F5F1EB;
    --dark: #0E0E0E;
    --mid: #2A2A2A;
    --muted: #7A7A7A;
    --border: #E0DBD3;
    --accent: #0E0E0E;
    --font-serif: 'DM Serif Display', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-sans);
    background: var(--cream);
    color: var(--dark);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── NAV ─────────────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 2.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #fff;
    mix-blend-mode: difference;
  }

  .nav-logo {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: inherit;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: inherit;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .nav-links a:hover { opacity: 1; }

  .nav-mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    padding: 8px;
    z-index: 101;
    position: relative;
  }
  .nav-mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
    margin: 5px 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  .nav-mobile-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-mobile-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-mobile-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--dark);
    z-index: 99;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    padding: 2rem;
  }
  .mobile-overlay.open { display: flex; }
  .mobile-overlay a {
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255,255,255,0.85);
    transition: color 0.2s;
  }
  .mobile-overlay a:hover { color: #fff; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-mobile-toggle { display: block; }
  }

  /* ─── FADE-IN ANIMATION ───────────────────────────────── */
  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
                transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .fade-in.delay-1 { transition-delay: 0.1s; }
  .fade-in.delay-2 { transition-delay: 0.2s; }
  .fade-in.delay-3 { transition-delay: 0.35s; }
  .fade-in.delay-4 { transition-delay: 0.5s; }

  /* ─── SHARED LAYOUT ───────────────────────────────────── */
  .section-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }
  .section-tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 1.2rem;
  }
  .section-heading {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.1;
    font-weight: 400;
  }
  .divider {
    height: 1px;
    background: var(--border);
  }
  .divider-dark {
    height: 1px;
    background: rgba(255,255,255,0.12);
  }

  /* ─── HERO ────────────────────────────────────────────── */
  #hero {
    background: var(--cream);
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 64px;
  }
  .hero-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 5rem 2.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 1.5rem;
  }
  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1.05;
    font-weight: 400;
    margin-bottom: 0.6rem;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--muted);
    margin-bottom: 1.8rem;
  }
  .hero-bio {
    font-size: 1rem;
    line-height: 1.75;
    color: #444;
    max-width: 440px;
    margin-bottom: 2.5rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--dark);
    border: 1.5px solid var(--dark);
    padding: 0.8rem 1.6rem;
    transition: background 0.2s, color 0.2s;
  }
  .btn:hover { background: var(--dark); color: var(--cream); }
  .btn-light {
    color: #fff;
    border-color: rgba(255,255,255,0.6);
  }
  .btn-light:hover { background: #fff; color: var(--dark); }

  .hero-image-wrap {
    position: relative;
  }
  .hero-portrait {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    object-position: top center;
    display: block;
    max-height: 350px;
    max-width: 350px
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-image-wrap { order: -1; max-width: 340px; }
  }

  /* ─── ABOUT STRIP ─────────────────────────────────────── */
  #about {
    background: var(--cream);
    padding: 5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }
  .about-quote {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.25;
    font-weight: 400;
  }
  .about-text { font-size: 0.97rem; line-height: 1.8; color: #444; }
  .about-text p + p { margin-top: 1rem; }

  @media (max-width: 720px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* ─── SKILLS ──────────────────────────────────────────── */
  #skills {
    background: #fff;
    padding: 7rem 0;
  }
  .skills-header { margin-bottom: 4rem; }
  .skills-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 6rem;
  }
  .skills-group { margin-bottom: 3rem; }
  .skills-group-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 1.6rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }
  .skill-bar-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .skill-bar-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.45rem;
  }
  .skill-bar-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--mid);
  }
  .skill-bar-years {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .skill-bar-track {
    height: 2px;
    background: var(--border);
    position: relative;
    overflow: visible;
  }
  .skill-bar-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: var(--dark);
    width: 0;
    transition: width 1.1s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .skill-bar-item.animate .skill-bar-fill {
    width: var(--bar-width);
  }
  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.4rem;
  }
  .skill-tag {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    color: var(--mid);
    background: var(--cream);
  }
  @media (max-width: 720px) {
    .skills-columns { grid-template-columns: 1fr; }
  }

  /* ─── PROJECTS (DARK) ─────────────────────────────────── */
  #projects {
    background: var(--dark);
    color: #f0ece4;
    padding: 7rem 0;
  }
  #projects .section-tag { opacity: 0.4; }
  #projects .section-heading { color: #f0ece4; }
  .project-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-top: 4rem;
  }
  .project-featured-text {}
  .project-kicker {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-bottom: 1rem;
  }
  .project-name {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.1;
    font-weight: 400;
    color: #f0ece4;
    margin-bottom: 1rem;
  }
  .project-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(240,236,228,0.65);
    margin-bottom: 1.5rem;
  }
  .project-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 2rem 0;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .stat-value {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: #f0ece4;
    display: block;
  }
  .stat-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-top: 0.2rem;
    display: block;
  }
  .project-image {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    object-position: top;
    display: block;
    opacity: 0.9;
  }
  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.5rem;
  }
  .tech-tag {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(240,236,228,0.6);
  }

  .ventures-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 5rem;
    padding-top: 5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .venture-card {
    padding: 2rem;
    border: 1px solid rgba(255,255,255,0.1);
    transition: border-color 0.2s;
  }
  .venture-card:hover { border-color: rgba(255,255,255,0.3); }
  .venture-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: #f0ece4;
    margin-bottom: 0.6rem;
  }
  .venture-desc {
    font-size: 0.88rem;
    line-height: 1.7;
    color: rgba(240,236,228,0.55);
    margin-bottom: 1.2rem;
  }

  @media (max-width: 860px) {
    .project-featured { grid-template-columns: 1fr; }
    .project-stats { grid-template-columns: repeat(2, 1fr); }
    .ventures-grid { grid-template-columns: 1fr; }
  }

  /* ─── EXPERIENCE ──────────────────────────────────────── */
  #experience {
    background: var(--cream);
    padding: 7rem 0;
  }
  .exp-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    margin-top: 4rem;
  }
  .exp-nav {
    position: sticky;
    top: 90px;
    align-self: start;
  }
  .exp-nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .exp-nav-list a {
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--muted);
    transition: color 0.2s;
    padding: 0.3rem 0;
    display: block;
    border-left: 2px solid transparent;
    padding-left: 1rem;
  }
  .exp-nav-list a:hover { color: var(--dark); border-left-color: var(--dark); }

  .exp-list { display: flex; flex-direction: column; gap: 0; }
  .exp-item {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .exp-item:first-child { border-top: 1px solid var(--border); }
  .exp-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }
  .exp-company {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
  }
  .exp-role {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .exp-date {
    font-size: 0.75rem;
    color: var(--muted);
    margin-left: auto;
    white-space: nowrap;
  }
  .exp-bullets {
    list-style: none;
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .exp-bullets li {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #444;
    padding-left: 1.2rem;
    position: relative;
  }
  .exp-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--muted);
  }
  .exp-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--dark);
    margin-top: 1.2rem;
    border-bottom: 1.5px solid var(--dark);
    padding-bottom: 1px;
    transition: opacity 0.2s;
  }
  .exp-link:hover { opacity: 0.6; }
  .exp-project-img {
    width: 100%;
    padding: 1rem 2rem;
    object-fit: cover;
    margin-top: 1.2rem;
    {# opacity: 0.85; #}
  }

  .exp-compare {
    position: relative;
    margin-top: 0.6rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #d8d2c9;
  }
  .exp-compare-after {
    display: block;
    width: 100%;
    height: auto;
    position: relative;
    z-index: 1;
    pointer-events: none;
  }
  .exp-compare-before {
    display: block;
    width: 100%;
    height: auto;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    pointer-events: none;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.55s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .exp-compare-before.show {
    clip-path: inset(0 0% 0 0);
  }

  .exp-compare-controls {
    display: flex;
    justify-content: flex-end;
    gap: 0.8rem;
    margin-top: 1rem;
  }
  .exp-compare-toggle {
    border: none;
    background: transparent;
    padding: 0;
    cursor: pointer;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .exp-compare-toggle:hover {
    color: var(--dark);
  }
  .exp-compare-toggle.active {
    color: var(--dark);
    border-bottom-color: var(--dark);
  }

  .exp-stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.85rem;
  }
  .exp-stack-tags span {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--border);
    background: transparent;
    color: #4a4a4a;
  }

  @media (max-width: 860px) {
    .exp-grid { grid-template-columns: 1fr; gap: 2rem; }
    .exp-nav { display: none; }
  }

  /* ─── EDUCATION ──────────────────────────────────────── */
  #education {
    background: #fff;
    padding: 7rem 0;
  }
  .edu-grid {
    display: flex;
    flex-direction: column;
  }
  .edu-meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }
  .edu-item {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: start;
  }
  .edu-institution {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    display: block;
    margin-bottom: 0.4rem;
  }
  .edu-date {
    font-size: 0.75rem;
    color: var(--muted);
    display: block;
    margin-bottom: 0.6rem;
    margin-left: auto;
  }
  .edu-degree {
    font-size: 0.88rem;
    font-weight: 600;
    display: block;
    color: var(--mid);
    margin-bottom: 0.2rem;
  }
  .edu-grade {
    font-size: 0.82rem;
    color: var(--muted);
    display: block;
  }
  @media (max-width: 720px) {
    .edu-item { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  /* ─── PHOTOGRAPHY ─────────────────────────────────────── */
  #photography {
    background: var(--dark);
    color: #f0ece4;
    padding: 7rem 0;
  }
  #photography .section-tag { opacity: 0.4; }
  .photo-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .photo-header .section-heading { color: #f0ece4; }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 0.75rem;
  }
  .photo-grid .photo-item:first-child {
    grid-column: 1 / span 2;
    grid-row: 1;
  }
  .photo-grid .photo-item:last-child {
    grid-column: 2 / span 2;
    grid-row: 3;
  }
  .photo-item {
    background: #1a1a1a;
    position: relative;
  }
  .photo-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.5s;
    opacity: 0.85;
    cursor: zoom-in;
  }
  .photo-item:hover img { transform: scale(1.04); opacity: 1; }

  .photo-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #1e1e1e 0%, #2a2a2a 50%, #1a1a1a 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    color: rgba(255,255,255,0.2);
  }
  .photo-placeholder svg { opacity: 0.3; }
  .photo-placeholder span {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .photo-credits {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .photo-credits-title {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-bottom: 1.2rem;
  }
  .photo-credits-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .photo-credit-tag {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.3rem 0.9rem;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(240,236,228,0.65);
    font-style: italic;
  }
  .video-section {
    margin-top: 4rem;
    padding-top: 4rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .video-section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
